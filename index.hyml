<!DOCTYPE html>

<html lang="zh-Hant">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>準提咒練習</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@400;500;600;700;900&family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Noto+Sans+TC:wght@300;400;500;600&display=swap');

*{box-sizing:border-box;}

body{
margin:0;
min-height:100vh;
background: #faf7f2;
color:#2b2926;
font-family:‘Noto Sans TC’, sans-serif;
display:flex;
flex-direction:column;
align-items:center;
padding:32px 16px 80px;
-webkit-font-smoothing:antialiased;
}

/* subtle texture removed for light theme clarity */

.wrap{ position:relative; z-index:1; width:100%; max-width:640px; }

header{ text-align:center; margin-bottom:28px; }
.eyebrow{
font-family:‘Cormorant Garamond’, serif;
font-style:italic;
letter-spacing:0.15em;
color:#5c574f;
font-size:14.5px;
margin-bottom:6px;
}
h1{
font-family:‘Noto Serif TC’, serif;
font-weight:900;
font-size:clamp(32px,8vw,44px);
margin:0;
letter-spacing:0.06em;
background:linear-gradient(180deg, #a98b5d, #5c574f);
-webkit-background-clip:text;
background-clip:text;
color:transparent;
}
.sub{
color:#5c574f;
font-size:15px;
margin-top:8px;
letter-spacing:0.02em;
}

.counter-row{
display:flex; align-items:center; justify-content:center; gap:18px;
margin:24px 0 20px;
}
.count-display{
font-family:‘Noto Serif TC’, serif;
font-size:16.5px;
font-weight:600;
color:#5c574f;
min-width:120px;
text-align:center;
}
.count-display b{
color:#a98b5d;
font-size:22px;
display:block;
font-weight:700;
}
button.round{
width:56px; height:56px;
border-radius:50%;
border:1px solid #e8e2d8;
background:#ffffff;
color:#a98b5d;
font-size:24px;
font-weight:700;
cursor:pointer;
transition: all .2s ease;
display:flex; align-items:center; justify-content:center;
touch-action: manipulation;
-webkit-tap-highlight-color: transparent;
}
button.round:hover{ border-color:#a98b5d; background:#faf7f2; transform:translateY(-1px); }
button.round:active{ transform:scale(0.94); }

/* –– Practice card –– */
.card{
background: #ffffff;
border:1px solid #e8e2d8;
border-radius:20px;
padding:36px 26px;
text-align:center;
position:relative;
overflow:hidden;
box-shadow: 0 2px 16px rgba(43,41,38,0.05);
}
.card::before{
content:“卍”;
position:absolute;
top:14px; left:16px;
font-size:14px;
color:#5c574f;
opacity:0.5;
}
.card::after{
content:“卍”;
position:absolute;
bottom:14px; right:16px;
font-size:14px;
color:#5c574f;
opacity:0.5;
}

.phrase-index{
font-family:‘Cormorant Garamond’, serif;
font-style:italic;
font-weight:600;
color:#a98b5d;
font-size:15px;
letter-spacing:0.1em;
margin-bottom:18px;
}

.han{
font-family:‘Noto Serif TC’, serif;
font-weight:700;
font-size:clamp(38px, 11vw, 56px);
line-height:1.3;
letter-spacing:0.06em;
color:#2b2926;
margin-bottom:16px;
min-height:1.3em;
}
.han .active{ color:#a98b5d; }

.pinyin{
font-family:‘Cormorant Garamond’, serif;
font-size:clamp(18px,5vw,24px);
font-weight:600;
color:#a98b5d;
letter-spacing:0.08em;
margin-bottom:6px;
min-height:1.4em;
}

.note{
font-size:16px;
font-weight:500;
color:#2b2926;
line-height:1.8;
max-width:420px;
margin:14px auto 0;
}

.audio-box{
margin: 4px auto 14px;
display:flex;
flex-direction:column;
align-items:center;
gap:6px;
}
.audio-box audio{
border-radius:999px;
height:40px;
}
.custom-play-btn{
display:inline-flex;
align-items:center;
gap:10px;
background:linear-gradient(180deg, #a98b5d, #5c574f);
color:#241c0c;
font-family:‘Noto Sans TC’, sans-serif;
font-weight:600;
font-size:15px;
padding:11px 28px;
border:none;
border-radius:999px;
cursor:pointer;
box-shadow:0 2px 10px rgba(169,139,93,0.3);
transition: all .15s ease;
}
.custom-play-btn:active{ transform:scale(0.96); }
.custom-progress-track{
width:100%;
max-width:280px;
height:4px;
background:#e8e2d8;
border-radius:2px;
margin-top:10px;
overflow:hidden;
}
.custom-progress-fill{
height:100%;
width:0%;
background:linear-gradient(90deg, #5c574f, #a98b5d);
transition: width .1s linear;
}
.audio-fallback{
font-size:13.5px;
color:#a98b5d;
text-decoration:underline;
font-family:‘Noto Sans TC’, sans-serif;
}
.audio-missing{
font-size:14px;
color:#5c574f;
margin: 4px auto 14px;
font-style:italic;
font-family:‘Cormorant Garamond’, serif;
}

.speak-btn{
display:inline-flex; align-items:center; gap:8px;
background:rgba(200,163,92,0.08);
border:1px solid #e8e2d8;
color:#a98b5d;
font-family:‘Noto Sans TC’, sans-serif;
font-size:15.5px;
padding:9px 20px;
border-radius:999px;
cursor:pointer;
margin-bottom:8px;
text-decoration:none;
transition: all .2s ease;
}
.speak-btn:hover{ border-color:#a98b5d; background:rgba(200,163,92,0.14); }
.speak-btn:active{ transform:scale(0.97); }
.speak-btn.speaking{ border-color:#a98b5d; background:rgba(200,163,92,0.2); }
.speak-icon{ font-size:14px; }

.voice-note{
text-align:center;
font-size:13.5px;
color:#5c574f;
margin-top:14px;
letter-spacing:0.02em;
}

.nav-row{
display:flex; align-items:center; justify-content:center; gap:20px;
margin-top:26px;
}
.nav-btn{
background:none; border:1px solid #e8e2d8;
color:#2b2926;
font-family:‘Noto Sans TC’, sans-serif;
padding:10px 20px;
border-radius:999px;
cursor:pointer;
font-size:14px;
transition: all .2s ease;
letter-spacing:0.03em;
}
.nav-btn:hover{ border-color:#a98b5d; color:#a98b5d; }
.nav-btn.primary{
background:linear-gradient(180deg, #a98b5d, #5c574f);
color:#241c0c;
border:none;
font-weight:600;
}
.nav-btn.primary:hover{ filter:brightness(1.08); }
.nav-btn:disabled{ opacity:0.3; cursor:default; }
.nav-btn:disabled:hover{ border-color:#e8e2d8; color:#2b2926; }

.progress-track{
width:100%; height:4px; background:#e8e2d8;
border-radius:2px; margin-top:28px; overflow:hidden;
}
.progress-fill{
height:100%; background:linear-gradient(90deg, #5c574f, #a98b5d);
transition: width .4s ease;
}

/* –– Full-text reference –– */
.full-text{
margin-top:36px;
border:1px solid #e8e2d8;
border-radius:16px;
padding:22px;
}
.full-text summary{
cursor:pointer;
font-family:‘Noto Serif TC’, serif;
font-weight:600;
color:#a98b5d;
font-size:15px;
letter-spacing:0.04em;
outline:none;
}
.full-line{
display:flex;
justify-content:space-between;
align-items:baseline;
padding:14px 4px;
border-bottom:1px dashed #e8e2d8;
cursor:pointer;
transition: background .15s ease;
gap:14px;
}
.full-line:last-child{ border-bottom:none; }
.full-line:hover{ background: rgba(200,163,92,0.06); }
.full-line .fh{ font-family:‘Noto Serif TC’, serif; font-weight:700; font-size:23px; color:#2b2926; }
.full-line .fp{ font-family:‘Cormorant Garamond’, serif; font-style:italic; font-weight:600; font-size:19px; color:#a98b5d; }
.full-list{ margin-top:16px; }
.section-head{
font-family:‘Noto Serif TC’, serif;
font-size:15px;
color:#a98b5d;
letter-spacing:0.1em;
margin:18px 0 4px;
padding-bottom:4px;
border-bottom:1px solid #e8e2d8;
}
.section-head:first-child{ margin-top:0; }

.mode-toggle{
display:flex; justify-content:center; gap:8px; margin-bottom:24px;
}
.mode-toggle button{
background:none; border:1px solid #e8e2d8; color:#5c574f;
padding:9px 18px; border-radius:999px; font-size:14.5px; font-weight:600; cursor:pointer;
font-family:‘Noto Sans TC’, sans-serif; transition: all .2s ease;
}
.mode-toggle button.on{
border-color:#a98b5d; color:#a98b5d; background:rgba(200,163,92,0.08);
}

.dedication-text{
font-family:‘Noto Serif TC’, serif;
font-size:17px;
font-weight:600;
line-height:2.3;
color:#2b2926;
text-align:left;
max-width:400px;
margin: 8px auto 0;
}
.dedication-text p{ margin:0 0 6px; }

footer{
margin-top:40px;
text-align:center;
font-size:13px;
color:#5c574f;
letter-spacing:0.05em;
font-family:‘Cormorant Garamond’, serif;
font-style:italic;
}
.ig-link{
margin-top:10px;
font-style:normal;
}
.ig-link a{
color:#a98b5d;
text-decoration:none;
font-family:‘Noto Sans TC’, sans-serif;
font-weight:600;
font-size:13px;
letter-spacing:0.02em;
display:inline-block;
max-width:280px;
text-align:center;
}
.ig-link a:active{ opacity:0.7; }

.full-mantra-card{
text-align:left;
}
.full-mantra-card .phrase-index{ text-align:center; }
.full-mantra-card .section-head{
text-align:center;
margin-top:22px;
}
.full-mantra-card .section-head:first-of-type{ margin-top:8px; }
.visualize-hint{
text-align:center;
font-size:13.5px;
font-weight:600;
color:#5c574f;
font-style:italic;
margin-top:20px;
padding-top:16px;
border-top:1px solid #e8e2d8;
}
.mantra-line{
display:flex;
justify-content:space-between;
align-items:center;
padding:12px 4px;
border-bottom:1px dashed #e8e2d8;
gap:10px;
}
.mantra-line:last-child{ border-bottom:none; }
.mantra-line .mh{
font-family:‘Noto Serif TC’, serif;
font-weight:700;
font-size:19px;
color:#2b2926;
flex-shrink:0;
}
.mantra-line .mp{
font-family:‘Cormorant Garamond’, serif;
font-style:italic;
font-weight:600;
font-size:15px;
color:#a98b5d;
text-align:right;
flex:1;
}
.mini-play-btn{
flex-shrink:0;
width:30px; height:30px;
border-radius:50%;
border:1px solid #e8e2d8;
background:#ffffff;
color:#a98b5d;
cursor:pointer;
display:flex; align-items:center; justify-content:center;
transition: all .15s ease;
}
.mini-play-btn:active{ transform:scale(0.9); }
.mini-play-btn.playing{
background:#a98b5d;
color:#fff;
border-color:#a98b5d;
}
.mini-play-icon{ font-size:11px; }

.goal-select{
display:flex;
align-items:center;
justify-content:center;
flex-wrap:wrap;
gap:8px;
margin: 6px auto 18px;
}
.goal-label{
font-size:13.5px;
color:#5c574f;
font-weight:600;
margin-right:2px;
}
.goal-btn{
background:none;
border:1px solid #e8e2d8;
color:#5c574f;
padding:7px 14px;
border-radius:999px;
font-size:13px;
font-weight:600;
cursor:pointer;
font-family:‘Noto Sans TC’, sans-serif;
transition: all .2s ease;
}
.goal-btn.on{
border-color:#a98b5d;
color:#a98b5d;
background:rgba(200,163,92,0.1);
}
.goal-progress-track{
width:100%; max-width:340px; margin:0 auto 6px;
height:6px; background:#e8e2d8; border-radius:3px; overflow:hidden;
}
.goal-progress-fill{
height:100%; width:0%;
background:linear-gradient(90deg, #5c574f, #a98b5d);
transition: width .2s ease;
}
.goal-progress-text{
text-align:center;
font-size:13px;
font-weight:600;
color:#5c574f;
margin-bottom:20px;
}

/* –– Completion / share screen –– */
.completion-overlay{
position:fixed;
inset:0;
z-index:100;
background:rgba(43,41,38,0.55);
display:flex;
flex-direction:column;
align-items:center;
justify-content:center;
padding:24px;
backdrop-filter: blur(3px);
}
.completion-card{
width:100%;
max-width:320px;
aspect-ratio: 9 / 14;
background:
linear-gradient(180deg, rgba(20,17,14,0.55) 0%, rgba(20,17,14,0.35) 45%, rgba(15,13,11,0.75) 100%),
url(‘cundi-bg.jpg’);
background-size: cover;
background-position: center 20%;
border-radius:24px;
display:flex;
flex-direction:column;
align-items:center;
justify-content:flex-end;
gap:8px;
padding:32px 20px 36px;
box-shadow: 0 20px 50px rgba(0,0,0,0.4);
position:relative;
overflow:hidden;
}
.completion-card::before{
content:””;
position:absolute;
inset:0;
background:
radial-gradient(circle at 50% 100%, rgba(20,17,14,0.55), transparent 60%);
}
.completion-mark{
font-size:34px;
color:#a98b5d;
opacity:0.9;
z-index:1;
}
.completion-title{
font-family:‘Noto Serif TC’, serif;
font-weight:900;
font-size:26px;
color:#fff;
letter-spacing:0.1em;
z-index:1;
}
.completion-goal{
font-family:‘Cormorant Garamond’, serif;
font-style:italic;
font-weight:700;
font-size:44px;
color:#a98b5d;
z-index:1;
}
.completion-sub{
font-family:‘Cormorant Garamond’, serif;
font-style:italic;
font-size:14px;
letter-spacing:0.15em;
color:rgba(255,255,255,0.75);
z-index:1;
}
.completion-date{
font-size:12px;
color:rgba(255,255,255,0.55);
margin-top:14px;
z-index:1;
}
.completion-ig{
font-family:‘Noto Sans TC’, sans-serif;
font-weight:600;
font-size:12px;
color:#a98b5d;
margin-top:6px;
max-width:240px;
text-align:center;
z-index:1;
}
.completion-actions{
display:flex;
gap:12px;
margin-top:24px;
}
.completion-actions .nav-btn{ background:#ffffff; }
.completion-hint{
margin-top:14px;
font-size:12.5px;
color:rgba(255,255,255,0.8);
text-align:center;
max-width:280px;
}

@media (prefers-reduced-motion: reduce){
*{ transition:none !important; }
}
</style>

<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>

</head>
<body>
<div class="wrap">

  <header>
    <div class="eyebrow">CUNDĪ DHĀRAṆĪ · 唸誦練習</div>
    <h1>準提咒</h1>
    <div class="sub">梵文羅馬拼音・中文對照・逐句練習</div>
  </header>

  <div class="mode-toggle">
    <button id="modePhrase" class="on">逐句練習</button>
    <button id="modeCount">持咒計數</button>
    <button id="modeDedication">迴向文</button>
  </div>

  <!-- PRACTICE MODE -->

  <div id="practiceView">
    <div class="card">
      <div class="phrase-index" id="phraseIndex">第 1 句 / 共 8 句</div>
      <div class="han" id="hanText"></div>
      <div class="pinyin" id="pinyinText"></div>
      <div id="audioBox" class="audio-box">
        <audio id="audioPlayer" preload="metadata" style="display:none;"></audio>
        <button id="audioPlayBtn" class="custom-play-btn" type="button">
          <span id="audioPlayIcon">▶</span>
          <span id="audioPlayLabel">播放錄音</span>
        </button>
        <div class="custom-progress-track"><div id="audioProgressFill" class="custom-progress-fill"></div></div>
        <a id="audioFallback" class="audio-fallback" href="#" target="_blank" rel="noopener" style="display:none;">無法播放？點此開啟音檔</a>
      </div>
      <div class="note" id="noteText"></div>
      <a class="speak-btn" id="videoLinkBtn" href="https://www.youtube.com/watch?v=7LHdmiZAXsE" target="_blank" rel="noopener">
        <span class="speak-icon">▶</span> 完整梵文教學可以點此連結（感謝本來無一物頻道）
      </a>
      <div class="progress-track"><div class="progress-fill" id="progressFill"></div></div>
    </div>

```
<div class="nav-row">
  <button class="nav-btn" id="prevBtn">← 上一句</button>
  <button class="nav-btn primary" id="playBtn">重新開始</button>
  <button class="nav-btn" id="nextBtn">下一句 →</button>
</div>
<div class="voice-note">「準提佛母心咒」各句已附上真人梵文錄音；開咒偈暫無錄音，可參照注音練習。</div>

<details class="full-text">
  <summary>查看全咒對照（梵文・中文）</summary>
  <div class="full-list" id="fullList"></div>
</details>
```

  </div>

  <!-- COUNTING MODE -->

  <div id="countView" style="display:none;">
    <div class="goal-select">
      <span class="goal-label">持咒目標：</span>
      <button class="goal-btn" data-goal="7">7 遍</button>
      <button class="goal-btn" data-goal="21">21 遍</button>
      <button class="goal-btn on" data-goal="108">108 遍</button>
      <button class="goal-btn" data-goal="0">不設定</button>
    </div>

```
<div class="goal-progress-track"><div id="goalProgressFill" class="goal-progress-fill"></div></div>
<div class="goal-progress-text" id="goalProgressText">目標：108 遍</div>

<div class="card full-mantra-card">
  <div class="phrase-index">持誦全咒・輕觸下方「+」計數，108 顆為一輪念珠</div>
  <div class="section-head">開咒偈（持誦一遍）</div>
  <div id="fullMantraOpening"></div>
  <div class="section-head">準提佛母心咒</div>
  <div id="fullMantraCore"></div>

  <div class="counter-row">
    <button class="round" id="resetBtn">↺</button>
    <div class="count-display">
      <b id="totalNum">0</b>
      遍
    </div>
    <button class="round" id="addBtn">+</button>
  </div>

  <div class="visualize-hint">持誦時不必太執著於發音準確，用心觀想準提菩薩，誠心相應即可</div>
</div>
```

  </div>

  <!-- DEDICATION MODE -->

  <div id="dedicationView" style="display:none;">
    <div class="card">
      <div class="phrase-index">迴向文・持咒圓滿後可默唸或朗誦</div>
      <div class="dedication-text">
        <p>願以此持咒功德，迴向給一切眾生。</p>
        <p>願眾生消除業障，福慧增長。</p>
        <p>願我（填入你的願望）順利成就。</p>
        <p>願以準提菩薩的加持，一切皆得圓滿。</p>
      </div>
    </div>
  </div>

  <!-- COMPLETION / SHARE MODAL -->

  <div id="completionModal" class="completion-overlay" style="display:none;">
    <div class="completion-card" id="completionCard">
      <div class="completion-mark">卍</div>
      <div class="completion-title">持咒圓滿</div>
      <div class="completion-goal" id="completionGoalText">108 遍</div>
      <div class="completion-sub">準提咒・CUNDĪ DHĀRAṆĪ</div>
      <div class="completion-date" id="completionDate"></div>
      <div class="completion-ig">made by 有意識生活練習 邱愣 @iamhere_mama</div>
    </div>
    <div class="completion-actions">
      <button class="nav-btn primary" id="shareCompletionBtn">下載圖片分享</button>
      <button class="nav-btn" id="closeCompletionBtn">關閉</button>
    </div>
    <div class="completion-hint">若你分享圖片可以tag @iamhere_mama 讓我知道你有在用🧡讓我有動力再繼續製作。</div>
  </div>

  <footer>
    namaḥ saptānāṃ · samyak sambuddha · koṭīnāṃ
    <div class="ig-link"><a href="https://www.instagram.com/iamhere_mama" target="_blank" rel="noopener">made by 有意識生活練習 邱愣 @iamhere_mama</a></div>
  </footer>
</div>

<script>
const phrases = [
  // 【開咒偈】不含音檔
  { section:"開咒偈", han:"稽首皈依蘇悉帝", zhuyin:"ㄑㄧˇ ㄕㄡˇ ㄍㄨㄟ ㄧ ㄙㄨ ㄒㄧ ㄉㄧˋ", san:"", note:"頂禮、皈依能夠圓滿成就一切心願的法寶。" },
  { section:"開咒偈", han:"頭面頂禮七俱胝", zhuyin:"ㄊㄡˊ ㄇㄧㄢˋ ㄉㄧㄥˇ ㄌㄧˇ ㄑㄧ ㄐㄩˋ ㄓ", san:"", note:"以頭面禮拜七千萬尊佛，皈依佛寶。" },
  { section:"開咒偈", han:"我今稱讚大準提", zhuyin:"ㄨㄛˇ ㄐㄧㄣ ㄔㄥ ㄗㄢˋ ㄉㄚˋ ㄓㄨㄣˇ ㄊㄧˊ", san:"", note:"我現在至誠稱讚與歌頌準提菩薩的功德，皈依僧寶。" },
  { section:"開咒偈", han:"惟願慈悲垂加護", zhuyin:"ㄨㄟˊ ㄩㄢˋ ㄘˊ ㄅㄟ ㄔㄨㄟˊ ㄐㄧㄚ ㄏㄨˋ", san:"", note:"祈求菩薩慈悲，給予我們護佑與加持。" },
  // 【準提佛母心咒】依實際持誦順序切分，各句附真人梵文錄音
  { section:"準提佛母心咒", han:"南無", san:"namaḥ", note:"皈依。", audio:"https://raw.githubusercontent.com/k740922/Cundi--audio/main/%E6%96%B0%E9%8C%84%E9%9F%B3%204.m4a" },
  { section:"準提佛母心咒", han:"颯多喃", san:"saptānām", note:"「七千萬」，與前句合為「皈依七千萬（諸佛）」。", audio:"https://raw.githubusercontent.com/k740922/Cundi--audio/main/%E6%96%B0%E9%8C%84%E9%9F%B3%208.m4a" },
  { section:"準提佛母心咒", han:"三藐", san:"samyak", note:"正等、圓滿之意。", audio:"https://raw.githubusercontent.com/k740922/Cundi--audio/main/%E6%96%B0%E9%8C%84%E9%9F%B3%209.m4a" },
  { section:"準提佛母心咒", han:"三菩陀", san:"sambuddha", note:"正覺，指佛陀圓滿的覺悟；合前句「三藐三菩陀」即「正等正覺」。", audio:"https://raw.githubusercontent.com/k740922/Cundi--audio/main/%E6%96%B0%E9%8C%84%E9%9F%B3%2010.m4a" },
  { section:"準提佛母心咒", han:"俱胝喃", san:"koṭīnām", note:"「俱胝」意為「千萬」，合前文為「七千萬正等正覺（諸佛）」。", audio:"https://raw.githubusercontent.com/k740922/Cundi--audio/main/%E6%96%B0%E9%8C%84%E9%9F%B3%2011.m4a" },
  { section:"準提佛母心咒", han:"怛姪他", san:"tadyathā", note:"意為「即說咒曰」，正文開始前的引語。", audio:"https://raw.githubusercontent.com/k740922/Cundi--audio/main/%E6%96%B0%E9%8C%84%E9%9F%B3%2012.m4a" },
  { section:"準提佛母心咒", han:"唵", san:"oṃ", note:"種子字，象徵身、口、意三密相應。", audio:"https://raw.githubusercontent.com/k740922/Cundi--audio/main/%E6%96%B0%E9%8C%84%E9%9F%B3%2013.m4a" },
  { section:"準提佛母心咒", han:"折隸", san:"cale", note:"準提菩薩的異名之一，象徵覺悟、昇進之德。", audio:"https://raw.githubusercontent.com/k740922/Cundi--audio/main/%E6%96%B0%E9%8C%84%E9%9F%B3%2014.m4a" },
  { section:"準提佛母心咒", han:"主隸", san:"cule", note:"準提菩薩的異名之一，象徵清淨、昇進之德。", audio:"https://raw.githubusercontent.com/k740922/Cundi--audio/main/%E6%96%B0%E9%8C%84%E9%9F%B3%2015.m4a" },
  { section:"準提佛母心咒", han:"準提", san:"cundi", note:"準提菩薩聖號，梵音 cundi（短音，接近「準低」），意譯為「清淨」。", audio:"https://raw.githubusercontent.com/k740922/Cundi--audio/main/%E6%96%B0%E9%8C%84%E9%9F%B3%2016.m4a" },
  { section:"準提佛母心咒", han:"娑婆訶", san:"svāhā", note:"意為「成就、圓滿、吉祥」，作為咒語結語。", audio:"https://raw.githubusercontent.com/k740922/Cundi--audio/main/%E6%96%B0%E9%8C%84%E9%9F%B3%2017.m4a" }
];

let idx = 0;

const hanEl = document.getElementById('hanText');
const pyEl = document.getElementById('pinyinText');
const noteEl = document.getElementById('noteText');
const idxEl = document.getElementById('phraseIndex');
const fillEl = document.getElementById('progressFill');
const prevBtn = document.getElementById('prevBtn');
const nextBtn = document.getElementById('nextBtn');
const playBtn = document.getElementById('playBtn');
const fullList = document.getElementById('fullList');

function setupAudio(playerEl, btnEl, iconEl, labelEl, progressEl, fallbackEl, url){
  if (url){
    playerEl.src = url;
    fallbackEl.href = url;
    fallbackEl.style.display = 'none';
    iconEl.textContent = '▶';
    labelEl.textContent = '播放錄音';
    progressEl.style.width = '0%';
    playerEl.load();
    btnEl.disabled = false;
  } else {
    playerEl.pause();
    playerEl.removeAttribute('src');
    fallbackEl.style.display = 'none';
    btnEl.disabled = true;
  }
}

function wireCustomPlayer(playerId, btnId, iconId, labelId, progressId, fallbackId){
  const player = document.getElementById(playerId);
  const btn = document.getElementById(btnId);
  const icon = document.getElementById(iconId);
  const label = document.getElementById(labelId);
  const progress = document.getElementById(progressId);
  const fallback = document.getElementById(fallbackId);

  btn.addEventListener('click', (e)=>{
    e.stopPropagation();
    if (player.paused){
      player.play().catch(()=>{
        fallback.style.display = 'inline-block';
      });
    } else {
      player.pause();
    }
  });
  player.addEventListener('play', ()=>{ icon.textContent = '❚❚'; label.textContent = '播放中'; });
  player.addEventListener('pause', ()=>{ icon.textContent = '▶'; label.textContent = '播放錄音'; });
  player.addEventListener('ended', ()=>{ icon.textContent = '▶'; label.textContent = '播放錄音'; progress.style.width = '0%'; });
  player.addEventListener('timeupdate', ()=>{
    if (player.duration){
      progress.style.width = `${(player.currentTime / player.duration) * 100}%`;
    }
  });
  player.addEventListener('error', ()=>{ fallback.style.display = 'inline-block'; }, true);

  return { player, btn, icon, label, progress, fallback };
}

const audioCtrl = wireCustomPlayer('audioPlayer','audioPlayBtn','audioPlayIcon','audioPlayLabel','audioProgressFill','audioFallback');

function renderPhrase(){
  hanEl.textContent = phrases[idx].han;
  if (phrases[idx].zhuyin){
    pyEl.textContent = phrases[idx].zhuyin;
    pyEl.style.display = '';
  } else if (phrases[idx].san){
    pyEl.textContent = phrases[idx].san;
    pyEl.style.display = '';
  } else {
    pyEl.textContent = '';
    pyEl.style.display = 'none';
  }
  noteEl.textContent = phrases[idx].note;
  idxEl.textContent = `${phrases[idx].section} ・ 第 ${idx+1} 句 / 共 ${phrases.length} 句`;
  fillEl.style.width = `${((idx+1)/phrases.length)*100}%`;
  prevBtn.disabled = idx === 0;
  nextBtn.disabled = idx === phrases.length - 1;

  const audioBox = document.getElementById('audioBox');
  const videoLinkBtn = document.getElementById('videoLinkBtn');
  if (phrases[idx].audio){
    setupAudio(audioCtrl.player, audioCtrl.btn, audioCtrl.icon, audioCtrl.label, audioCtrl.progress, audioCtrl.fallback, phrases[idx].audio);
    audioBox.style.display = '';
    videoLinkBtn.style.display = '';
  } else {
    setupAudio(audioCtrl.player, audioCtrl.btn, audioCtrl.icon, audioCtrl.label, audioCtrl.progress, audioCtrl.fallback, null);
    audioBox.style.display = 'none';
    videoLinkBtn.style.display = 'none';
  }
}

prevBtn.addEventListener('click', ()=>{ if(idx>0){ idx--; renderPhrase(); } });
nextBtn.addEventListener('click', ()=>{ if(idx<phrases.length-1){ idx++; renderPhrase(); } });
playBtn.addEventListener('click', ()=>{ idx=0; renderPhrase(); });

function buildFullList(){
  fullList.innerHTML = '';
  let lastSection = '';
  phrases.forEach((p,i)=>{
    if (p.section !== lastSection){
      const head = document.createElement('div');
      head.className = 'section-head';
      head.textContent = p.section;
      fullList.appendChild(head);
      lastSection = p.section;
    }
    const row = document.createElement('div');
    row.className = 'full-line';
    row.innerHTML = `<span class="fh">${p.han}</span><span class="fp">${p.zhuyin || p.san || ''}</span>`;
    row.addEventListener('click', ()=>{
      idx = i; renderPhrase();
      document.getElementById('modePhrase').click();
      window.scrollTo({top:0, behavior:'smooth'});
    });
    fullList.appendChild(row);
  });
}

renderPhrase();
buildFullList();


/* ---- Counting mode ---- */
const totalNum = document.getElementById('totalNum');

const mantraOpening = phrases.filter(p => p.section === '開咒偈');
const mantraCore = phrases.filter(p => p.section === '準提佛母心咒');

function renderFullMantra(){
  const openingEl = document.getElementById('fullMantraOpening');
  const coreEl = document.getElementById('fullMantraCore');
  openingEl.innerHTML = mantraOpening.map(p =>
    `<div class="mantra-line"><span class="mh">${p.han}</span><span class="mp">${p.zhuyin || ''}</span></div>`
  ).join('');
  coreEl.innerHTML = mantraCore.map((p,i) =>
    `<div class="mantra-line">
      <span class="mh">${p.han}</span>
      <span class="mp">${p.san || ''}</span>
      ${p.audio ? `<button type="button" class="mini-play-btn" data-audio-idx="${i}" aria-label="播放 ${p.han}"><span class="mini-play-icon">▶</span></button>` : ''}
    </div>`
  ).join('');

  coreEl.querySelectorAll('.mini-play-btn').forEach(btn=>{
    btn.addEventListener('click', ()=>{
      const i = parseInt(btn.getAttribute('data-audio-idx'), 10);
      playMiniAudio(mantraCore[i].audio, btn);
    });
  });
}
renderFullMantra();

const miniAudioPlayer = new Audio();
let currentMiniBtn = null;
function resetMiniBtn(btn){
  if (btn){
    btn.classList.remove('playing');
    btn.querySelector('.mini-play-icon').textContent = '▶';
  }
}
function playMiniAudio(url, btn){
  if (currentMiniBtn === btn && !miniAudioPlayer.paused){
    miniAudioPlayer.pause();
    resetMiniBtn(btn);
    currentMiniBtn = null;
    return;
  }
  resetMiniBtn(currentMiniBtn);
  miniAudioPlayer.src = url;
  miniAudioPlayer.play().catch(()=>{});
  btn.classList.add('playing');
  btn.querySelector('.mini-play-icon').textContent = '❚❚';
  currentMiniBtn = btn;
}
miniAudioPlayer.addEventListener('ended', ()=>{
  resetMiniBtn(currentMiniBtn);
  currentMiniBtn = null;
});


let total = 0;
let goal = 108;
let goalCelebrated = false;

const goalProgressFill = document.getElementById('goalProgressFill');
const goalProgressText = document.getElementById('goalProgressText');

function updateGoalProgress(){
  if (goal > 0){
    const pct = Math.min((total / goal) * 100, 100);
    goalProgressFill.style.width = `${pct}%`;
    if (total >= goal){
      goalProgressText.textContent = `🎉 已圓滿 ${goal} 遍！`;
    } else {
      goalProgressText.textContent = `目標：${total} / ${goal} 遍`;
    }
  } else {
    goalProgressFill.style.width = '0%';
    goalProgressText.textContent = '自由持誦・未設定目標遍數';
  }
}
updateGoalProgress();

document.querySelectorAll('.goal-btn').forEach(btn=>{
  btn.addEventListener('click', ()=>{
    document.querySelectorAll('.goal-btn').forEach(b=>b.classList.remove('on'));
    btn.classList.add('on');
    goal = parseInt(btn.getAttribute('data-goal'), 10);
    goalCelebrated = false;
    updateGoalProgress();
  });
});

function addCount(){
  total++;
  totalNum.textContent = total;
  updateGoalProgress();
  if (goal > 0 && total >= goal && !goalCelebrated){
    goalCelebrated = true;
    showCompletionScreen();
  }
}

document.getElementById('addBtn').addEventListener('click', addCount);
document.getElementById('resetBtn').addEventListener('click', ()=>{
  total = 0; goalCelebrated = false;
  totalNum.textContent = 0;
  updateGoalProgress();
});

/* ---- Completion / share screen ---- */
function showCompletionScreen(){
  const modal = document.getElementById('completionModal');
  const goalText = document.getElementById('completionGoalText');
  const dateEl = document.getElementById('completionDate');
  goalText.textContent = `${goal} 遍`;
  const now = new Date();
  const dateStr = `${now.getFullYear()}.${String(now.getMonth()+1).padStart(2,'0')}.${String(now.getDate()).padStart(2,'0')}`;
  dateEl.textContent = dateStr;
  modal.style.display = 'flex';
}

document.getElementById('closeCompletionBtn').addEventListener('click', ()=>{
  document.getElementById('completionModal').style.display = 'none';
});

document.getElementById('shareCompletionBtn').addEventListener('click', async ()=>{
  const btn = document.getElementById('shareCompletionBtn');
  const originalLabel = btn.textContent;
  btn.textContent = '圖片產生中…';
  btn.disabled = true;

  try {
    const cardEl = document.getElementById('completionCard');
    const canvas = await html2canvas(cardEl, {
      useCORS: true,
      backgroundColor: null,
      scale: 2
    });

    const blob = await new Promise(resolve => canvas.toBlob(resolve, 'image/png'));
    const fileName = `準提咒持咒圓滿_${goal}遍.png`;
    const file = new File([blob], fileName, { type: 'image/png' });
    const shareText = `我今日圓滿持誦準提佛母心咒 ${goal} 遍 🙏 有意識生活練習 邱愣 @iamhere_mama`;

    if (navigator.canShare && navigator.canShare({ files: [file] })){
      await navigator.share({ files: [file], text: shareText, title: '準提咒持咒圓滿' });
    } else {
      // 不支援分享圖片檔案時，直接觸發下載，讓使用者手動分享到限動
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = fileName;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
      alert('圖片已下載，請到相簿選取這張圖分享到 IG 限時動態');
    }
  } catch(err){
    alert('圖片產生失敗，請直接長按或截圖上方畫面分享到限時動態');
  } finally {
    btn.textContent = originalLabel;
    btn.disabled = false;
  }
});

/* ---- mode toggle ---- */
const modePhrase = document.getElementById('modePhrase');
const modeCount = document.getElementById('modeCount');
const modeDedication = document.getElementById('modeDedication');
const practiceView = document.getElementById('practiceView');
const countView = document.getElementById('countView');
const dedicationView = document.getElementById('dedicationView');

function setMode(active){
  const modes = [
    { btn: modePhrase, view: practiceView },
    { btn: modeCount, view: countView },
    { btn: modeDedication, view: dedicationView }
  ];
  modes.forEach(m=>{
    const isActive = m.btn === active.btn;
    m.btn.classList.toggle('on', isActive);
    m.view.style.display = isActive ? '' : 'none';
  });
}

modePhrase.addEventListener('click', ()=> setMode({btn: modePhrase}));
modeCount.addEventListener('click', ()=> setMode({btn: modeCount}));
modeDedication.addEventListener('click', ()=> setMode({btn: modeDedication}));
</script>

</body>
</html>
